# NextAuth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=your_secret_here

# Mock data toggle (default: true — set to "false" to use live TikTok API)
MOCK_DATA=true

# TikTok Shop API credentials (only needed when MOCK_DATA=false)
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
