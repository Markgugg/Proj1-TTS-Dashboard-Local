# NextAuth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=your_secret_here

# Mock data toggle (default: true — set to "false" to use Supabase)
MOCK_DATA=true

# Supabase (only needed when MOCK_DATA=false)
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# TikTok Shop API credentials (future — live data sync)
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
